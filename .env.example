# Cortex Configuration

# Server port
PORT=3001

# Projects directory (where state files are located)
PROJECTS_DIR=C:\Users\boomb\Documents\_Projects

# Obsidian vault directory (primary — required)
VAULT_DIR=C:\Users\boomb\Documents\SecondBrain

# Additional vault directories (optional, comma-separated absolute paths)
# TODOs and deadlines will be scanned from all configured vaults.
# Non-existent paths are skipped with a warning log.
# Example: VAULT_DIRS=C:\Users\boomb\Notes\AppleNotes,D:\Logseq
VAULT_DIRS=

# Claude API key (optional, for AI features)
ANTHROPIC_API_KEY=

# Notes corpus file (optional)
NOTES_CORPUS=C:\Users\boomb\Documents\notes_corpus.txt.txt

# ntfy push notifications (https://ntfy.sh)
NTFY_TOPIC=
NTFY_DIGEST_TIME=08:00
NTFY_URL=https://ntfy.sh

# Ollama local AI (https://ollama.ai)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Google Calendar OAuth2 (optional)
# See README.md "Google Calendar Setup" section for instructions
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/calendar/callback
