{
  "name": "cortex",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "node scripts/dev-runner.cjs",
    "dev:frontend": "vite",
    "dev:backend": "tsx watch server/index.ts",
    "dev:ollama": "node scripts/start-ollama.cjs",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "mcp:dev": "tsx server/mcp-server.ts",
    "mcp:build": "tsc --project tsconfig.node.json --outDir dist-mcp server/mcp-server.ts server/lib/mcp-tools.ts",
    "electron:compile": "esbuild electron/main.ts --bundle --platform=node --outfile=dist-electron/main.cjs --external:electron && esbuild electron/preload.ts --bundle --platform=node --outfile=dist-electron/preload.cjs --external:electron",
    "electron:dev": "npm run electron:compile && node scripts/dev-runner.cjs --electron",
    "electron:build": "npm run build && node scripts/bundle-server.mjs && npm run electron:compile && electron-builder"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/d3": "^7.4.3",
    "cheerio": "^1.2.0",
    "cmdk": "^1.1.1",
    "cors": "^2.8.5",
    "csv-parse": "^6.2.1",
    "d3": "^7.9.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "glob": "^13.0.6",
    "googleapis": "^171.4.0",
    "node-ical": "^0.26.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.14.2",
    "recharts": "^3.8.1",
    "simple-git": "^3.36.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "@types/react": "^18.2.46",
    "@types/react-dom": "^18.2.18",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "cross-env": "^10.1.0",
    "electron": "^41.2.2",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "happy-dom": "^20.8.9",
    "jsdom": "^29.0.1",
    "postcss": "^8.4.32",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.10",
    "vitest": "^1.1.0"
  },
  "build": {
    "appId": "com.cortex.dashboard",
    "productName": "Cortex",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-server/**/*",
      "dist-electron/**/*",
      "build/icon.png",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "build/icon.png",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "build/icon.png",
      "category": "Utility"
    }
  }
}
