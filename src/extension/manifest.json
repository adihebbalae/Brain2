{
  "manifest_version": 3,
  "name": "Cortex Clipper",
  "version": "1.0.0",
  "description": "Clip the current page to your Cortex inbox",
  "permissions": ["activeTab"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.svg",
      "48": "icons/icon48.svg",
      "128": "icons/icon128.svg"
    }
  }
}
